# Navos production env example
# 复制为 .env 后，只需要填写“必填区”。其余保持默认即可。

# =========================
# 1. 必填：服务鉴权和上游
# =========================
# 管理后台 Master Key，本服务本地管理接口使用。
MASTER_API_KEY=sk-local-master-change-me

# 对外售卖 / Sub2Api 调用本服务时允许使用的 key，多个用英文逗号分隔。
PUBLIC_PROXY_API_KEYS=sk-local-public-proxy-change-me

# Navos 上游后端地址。
PROVIDER_BASE_URL=https://provider.example.com

# VIP 接口签名密钥，用于注册、查余额、余额恢复。
VIP_HMAC_SECRET=change-me

# =========================
# 2. 必填：MySQL
# =========================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=navos_new

# =========================
# 3. 推荐生产开关
# =========================
# false：图片只用 100-1999 分账号，2000 分账号保留给 Seedance 视频。
# true：图片池不够时允许吃 2000 分视频储备账号。
IMAGE_ALLOW_VIDEO_RESERVE_FALLBACK=false

# =========================
# 4. 常用可选项：图片任务
# =========================
# 图片账号不够时最多等待多久；生产建议 120000，也就是 2 分钟。
# IMAGE_ACCOUNT_WAIT_MS=120000
# IMAGE_MAX_POLL_ATTEMPTS=30
# IMAGE_POLL_INTERVAL_MS=4000

# =========================
# 5. 常用可选项：余额恢复
# =========================
# depleted 账号会定时查 VIP 余额；有额度就自动恢复 active。
# ACCOUNT_BALANCE_RECONCILE_ENABLED=true
# ACCOUNT_BALANCE_RECONCILE_INTERVAL_MINUTES=30
# ACCOUNT_BALANCE_RECONCILE_BATCH_SIZE=1000
# ACCOUNT_BALANCE_RECONCILE_CONCURRENCY=5

# =========================
# 6. 可选：注册机目标和队列
# =========================
# POOL_TARGET_SIZE=0
# REGISTRATION_CONCURRENCY=2
# REDIS_URL=redis://127.0.0.1:6379
# QUEUE_PREFIX=navos
# REGISTRATION_JOB_CONCURRENCY=1
# REGISTRATION_JOB_REMOVE_ON_COMPLETE=50
# REGISTRATION_JOB_REMOVE_ON_FAIL=100

# =========================
# 7. 高级：YYDS 注册并发细分
# =========================
# 下面这些不是废弃项，只是高级调参项；不确定就别开。
# REGISTRATION_MAX_IN_FLIGHT=6
# REGISTRATION_MAILBOX_CREATE_CONCURRENCY=2
# REGISTRATION_MAILBOX_CREATE_PER_SECOND=2
# REGISTRATION_VIP_SEND_CONCURRENCY=6
# REGISTRATION_POLL_CONCURRENCY=30
# REGISTRATION_LOGIN_CONCURRENCY=6
# REGISTRATION_CERT_CONCURRENCY=4
# REGISTRATION_VERIFICATION_TIMEOUT_MS=90000

# =========================
# 8. 高级：YYDS 域名池
# =========================
# YYDS_DOMAIN_POOL_ENABLED=true
# YYDS_DOMAIN_POOL_MODE=auto-plus-whitelist
# YYDS_DOMAIN_REFRESH_MINUTES=30
# YYDS_DOMAIN_WHITELIST=
# YYDS_DOMAIN_BLACKLIST=

# =========================
# 9. 高级：服务监听 / 认证模式
# =========================
# PORT=18888
# PROVIDER_AUTH_MODE=uid-token
# PROVIDER_ACCOUNT_UID=
# PROVIDER_ACCOUNT_TOKEN=
# VIP_BASE_URL=https://navos-mind-server-vip.tec-do.com

