# Navos open-source env example
# 复制为 .env 后，默认只需要改 MASTER_API_KEY 和 PUBLIC_PROXY_API_KEYS。
# YYDS Mail Key 不写在 .env，启动后进入 Web 控制台「YYDS 配置」填写。

# 1. 本地鉴权：必须改成你自己的值
MASTER_API_KEY=sk-local-master-change-me
PUBLIC_PROXY_API_KEYS=sk-local-public-proxy-change-me

# 2. 上游 NavOS / VIP：已内置可用默认值，普通用户不用改
PROVIDER_BASE_URL=https://navos-mind-server-backend.tec-do.com
VIP_HMAC_SECRET=5c1d6c1dcd777dbe26f1422f03e5b3749ed87432
VIP_BASE_URL=https://navos-mind-server-vip.tec-do.com

# 3. MySQL：默认值可直接配合 docker compose 使用
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=navos-local-password
MYSQL_DATABASE=navos_new
MYSQL_CONNECTION_LIMIT=100
MYSQL_QUEUE_LIMIT=0

# 4. Redis / 注册任务队列
REDIS_URL=redis://127.0.0.1:6379
QUEUE_PREFIX=navos

# 5. 服务监听 / 上游认证
PORT=18888
PROVIDER_AUTH_MODE=uid-token
PROVIDER_ACCOUNT_UID=
PROVIDER_ACCOUNT_TOKEN=

# 运行参数在 Web 控制台调整：
# 图片/视频超时、余额检查范围、注册吞吐、YYDS 熔断、域名池等。
