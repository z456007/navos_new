# Navos production env example
# 复制为 .env 后，只需要填写本文件里的启动必需项。

# 1. 服务鉴权和上游
MASTER_API_KEY=sk-local-master-change-me
PUBLIC_PROXY_API_KEYS=sk-local-public-proxy-change-me
PROVIDER_BASE_URL=https://provider.example.com
VIP_HMAC_SECRET=change-me
VIP_BASE_URL=https://navos-mind-server-vip.tec-do.com

# 2. MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=navos_new
MYSQL_CONNECTION_LIMIT=100
MYSQL_QUEUE_LIMIT=0

# 3. Redis / 注册任务队列
REDIS_URL=redis://127.0.0.1:6379
QUEUE_PREFIX=navos

# 4. 服务监听 / 上游认证
PORT=18888
PROVIDER_AUTH_MODE=uid-token
PROVIDER_ACCOUNT_UID=
PROVIDER_ACCOUNT_TOKEN=

# 运行参数在 Web 控制台调整；.env 只保留启动必需项。
# 包括：图片/视频超时、余额检查范围、注册吞吐、YYDS 熔断、域名池。
